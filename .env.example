# Copy to `.env` in the repo root. Do not commit `.env`.
#
# Generate a secret:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# PostgreSQL connection string (production / local Postgres).
DATABASE_URL=

# Optional: some hosts provide a separate session or pooler URL.
# DATABASE_SESSION_URL=

# Optional: comma-separated origins for CORS.
# CORS_ORIGINS=http://localhost:5173

# Email verification for new accounts (set false for quick local dev without SMTP).
# EMAIL_VERIFICATION_REQUIRED=true

# SMTP (password reset + verification emails). Leave unset to disable sending.
# Gmail example (use an App Password, not your normal password):
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USE_SSL=false
# MAIL_USERNAME=you@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=you@gmail.com
#
# Alternative: port 465 implicit SSL
# MAIL_PORT=465
# MAIL_USE_TLS=false
# MAIL_USE_SSL=true
#
# Demo seed (see docs/DEPLOYMENT.md): local SQLite only unless
# MZANSI_ALLOW_DEMO_SEED=1
